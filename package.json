{
  "name": "la-corsa-invisibile",
  "version": "0.1.0",
  "private": true,
  "description": "La Corsa Invisibile — GdR multiplayer legato al romanzo 'Il ragazzo che correva nel tempo'. Progetto indipendente, non condivide database né deploy con Session Zero.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute la-corsa-invisibile-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute la-corsa-invisibile-db --remote --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "simulatore-interprete": "github:simo0703/simulatore-interprete#f2aa39c2222831dcea01c519d079de7faf54a019",
    "snowball-stemmers": "^0.6.0"
  }
}
